{
  "name": "codejury",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous mixture-of-experts code review agent",
  "bin": {
    "cj": "./packages/cli/dist/index.js",
    "codejury": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:cli": "turbo run dev --filter=@codejury/cli",
    "dev:tui": "turbo run dev --filter=@codejury/tui",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "postinstall": "npm run build --if-present || true"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.6.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/eagleisbatman/codejury.git"
  },
  "keywords": ["code-review", "ai-agents", "mixture-of-experts", "cli", "tui"],
  "license": "MIT"
}
